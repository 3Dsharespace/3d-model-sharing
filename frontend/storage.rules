rules_version = '2';

// Firebase Storage Rules for 3D Model Platform - Enhanced Security
service firebase.storage {
  match /b/{bucket}/o {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
             firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
             (firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
    }
    
    // Allow all authenticated users to read everything
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Model files + previews (supports nested folders like previews/)
    match /models/{userId}/{modelId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() &&
                   request.auth.uid == userId &&
                   fileName.matches('^[A-Za-z0-9._ -]+$') &&
                   fileName.matches('.*\\.(glb|GLB|gltf|GLTF|obj|OBJ|fbx|FBX|3ds|3DS|dae|DAE|stl|STL|ply|PLY|zip|ZIP|rar|RAR|7z|7Z)$') &&
                   request.resource.size < 250 * 1024 * 1024;
    }

    match /models/{userId}/{modelId}/previews/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() &&
                   request.auth.uid == userId &&
                   fileName.matches('^[A-Za-z0-9._ -]+$') &&
                   request.resource.size < 10 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*');
    }

    match /models/{userId}/{modelId}/{rest=**} {
      allow read: if true;
      allow write: if isAuthenticated() &&
                   (request.auth.uid == userId || isAdmin()) &&
                   // Path sanity
                   rest.matches('^[A-Za-z0-9._/-]+$') &&
                   // Block dangerous extensions anywhere in path
                   !rest.matches('.*(\\.|/)(exe|bat|cmd|com|pif|scr|vbs|js|jar|dll|sys|php|asp|aspx|jsp|pl|py|rb|sh|ps1|psm1|psd1|ps1xml|psc1|pssc|psrc|cdxml|vbe|wsf|wsh|msc|hta|reg|inf|lnk|url)$') &&
                   (
                     // Previews/thumbnails/images: images only, smaller
                     (rest.matches('(previews|thumbnails|images)/.*') &&
                      request.resource.size < 10 * 1024 * 1024 &&
                      request.resource.contentType.matches('image/.*')) ||
                     // Model files or archives: larger, restricted content-types
                     (!rest.matches('(previews|thumbnails|images)/.*') &&
                      request.resource.size < 100 * 1024 * 1024 &&
                      rest.matches('.*\\.(glb|gltf|obj|fbx|FBX|3ds|dae|stl|ply|zip|rar|7z)$') &&
                      (request.resource.contentType == '' ||
                       request.resource.contentType.matches('model/.*') ||
                       request.resource.contentType.matches('application/octet-stream') ||
                       request.resource.contentType.matches('application/.*')))
                   );
    }
    
    // Thumbnails - strict image validation
    match /thumbnails/{userId}/{modelId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && 
                   (request.auth.uid == userId || isAdmin()) &&
                   request.resource.size < 10 * 1024 * 1024 && // 10MB limit
                   request.resource.contentType.matches('image/.*') &&
                   fileName.matches('^[a-zA-Z0-9._-]+$') && // Safe filename only
                   fileName.matches('.*\\.(jpg|jpeg|png|webp|gif)$'); // Only image extensions
    }
    
    // Model images - strict image validation
    match /model_images/{userId}/{modelId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && 
                   (request.auth.uid == userId || isAdmin()) &&
                   request.resource.size < 10 * 1024 * 1024 && // 10MB limit
                   request.resource.contentType.matches('image/.*') &&
                   fileName.matches('^[a-zA-Z0-9._-]+$') && // Safe filename only
                   fileName.matches('.*\\.(jpg|jpeg|png|webp|gif)$'); // Only image extensions
    }
    
    // Additional images - strict image validation
    match /images/{userId}/{modelId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && 
                   (request.auth.uid == userId || isAdmin()) &&
                   request.resource.size < 10 * 1024 * 1024 && // 10MB limit
                   request.resource.contentType.matches('image/.*') &&
                   fileName.matches('^[a-zA-Z0-9._-]+$') && // Safe filename only
                   fileName.matches('.*\\.(jpg|jpeg|png|webp|gif)$'); // Only image extensions
    }
    
    // Additional files - restricted file types
    match /files/{userId}/{modelId}/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated() && 
                   (request.auth.uid == userId || isAdmin()) &&
                   request.resource.size < 50 * 1024 * 1024 && // 50MB limit
                   fileName.matches('^[a-zA-Z0-9._-]+$') && // Safe filename only
                   fileName.matches('.*\\.(txt|pdf|doc|docx|zip|rar|7z|obj|fbx|stl|gltf|glb|dae|3ds|mtl|tga|png|jpg|jpeg|hdr|exr|tif|tiff|mp4|avi|mov|wmv|flv|webm|mp3|wav|ogg|aac|flac|wma)$'); // Only safe file extensions
    }
    
    // Profile avatars - strict image validation
    match /avatars/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && 
                   request.auth.uid == userId &&
                   request.resource.size < 5 * 1024 * 1024 && // 5MB limit
                   request.resource.contentType.matches('image/.*') &&
                   fileName.matches('^[a-zA-Z0-9._-]+$') && // Safe filename only
                   fileName.matches('.*\\.(jpg|jpeg|png|webp|gif)$'); // Only image extensions
    }
    
    // NOTE: Storage rules cannot call Firestore get/exists.
    // If you later adopt a modelId-only storage path, enforce writes via Cloud Functions.

    // Profile pictures: profiles/{fileName} where fileName starts with profile_{uid}_
    match /profiles/{fileName} {
      allow read: if true;
      allow write: if request.auth != null &&
                   request.resource.size < 5 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*') &&
                   fileName.matches('^profile_' + request.auth.uid + '_[A-Za-z0-9._-]+$') &&
                   fileName.matches('.*\\.(jpg|jpeg|png|webp)$');
    }

    // Banners: banners/{fileName} where fileName starts with banner_{uid}_
    match /banners/{fileName} {
      allow read: if true;
      allow write: if request.auth != null &&
                   request.resource.size < 10 * 1024 * 1024 &&
                   request.resource.contentType.matches('image/.*') &&
                   fileName.matches('^banner_' + request.auth.uid + '_[A-Za-z0-9._-]+$') &&
                   fileName.matches('.*\\.(jpg|jpeg|png|webp)$');
    }
    
    // Legacy catch-all - more restrictive
    match /{allPaths=**} {
      allow write: if false; // Disable catch-all uploads for security
    }
  }
}
