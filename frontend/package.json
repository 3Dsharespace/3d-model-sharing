{
  "name": "3dsharespace-frontend",
  "version": "1.0.0",
  "description": "Frontend for 3D model sharing platform",
  "type": "module",
  "scripts": {
    "dev": "vite --force",
    "dev:mobile": "node scripts/mobile-test.js",
    "build": "node ./node_modules/vite/bin/vite.js build && node ./scripts/prerender-seo-pages.js && node ./scripts/prerender-guide-pages.js && node ./scripts/prerender-model-pages.js && node ./scripts/generate-static-sitemap.js && node ./scripts/generate-model-sitemaps.js",
    "seo:static-sitemap": "node ./scripts/generate-static-sitemap.js",
    "seo:sitemaps": "node ./scripts/generate-model-sitemaps.js",
    "preview": "vite preview",
    "preview:mobile": "vite preview --host 0.0.0.0",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "chart.js": "^4.5.0",
    "clsx": "^2.0.0",
    "firebase": "^12.1.0",
    "framer-motion": "^12.23.12",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.3.8",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.48.2",
    "react-hot-toast": "^2.5.2",
    "react-router-dom": "^6.20.1",
    "tailwind-merge": "^2.0.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^23.0.1",
    "postcss": "^8.4.32",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.6",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^5.0.0",
    "vitest": "^1.0.4"
  },
  "keywords": [
    "react",
    "3d",
    "models",
    "sharing",
    "platform"
  ],
  "author": "3Dsharespace Team",
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  }
}
